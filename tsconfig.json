{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,

    "allowJs": false,

    "noImplicitAny": true,

    "strictNullChecks": true,

    "isolatedModules": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "lib": [
      "DOM",
      "ES2022"
    ],

    "types": [
      "vite/client"
    ]
  },

  "include": [
    "src"
  ]
}
